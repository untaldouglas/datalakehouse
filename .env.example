# ============================================================
# Universidad Data Lakehouse - Configuration Template
# Copy this file to .env and adjust values as needed
# ============================================================

# --- University Identity ---
UNIVERSITY_NAME="Universidad Nacional Ficticia"
UNIVERSITY_CODE="UNF"
NUM_STUDENTS=5000
TIMEZONE=America/El_Salvador

# --- Moodle ---
MOODLE_VERSION=4.3.0
MOODLE_PORT=8080
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=Admin1234!
MOODLE_ADMIN_EMAIL=admin@universidad.edu
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=moodle_secret_2024
MYSQL_ROOT_PASSWORD=mysql_root_secret_2024

# --- ERPNext (MariaDB backend) ---
ERPNEXT_VERSION=v15
MARIADB_ROOT_PASSWORD=mariadb_root_secret_2024
ERPNEXT_DB_NAME=erpnext_universidad
ERPNEXT_DB_USER=erpnext
ERPNEXT_DB_PASSWORD=erpnext_secret_2024

# --- MinIO Object Storage ---
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET_LAKEHOUSE=lakehouse
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_SILVER=silver
MINIO_BUCKET_GOLD=gold

# --- Nessie Iceberg Catalog ---
NESSIE_VERSION=0.108.0
NESSIE_PORT=19120

# --- Dremio OSS ---
DREMIO_VERSION=25.0
DREMIO_UI_PORT=9047
DREMIO_JDBC_PORT=31010
DREMIO_FLIGHT_PORT=32010
DREMIO_ADMIN_USER=admin
DREMIO_ADMIN_PASSWORD=Admin1234!
DREMIO_ADMIN_EMAIL=admin@universidad.edu

# --- Apache Airflow ---
AIRFLOW_PORT=8090
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow_secret_2024
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=Admin1234!
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here_replace_me
AIRFLOW_SECRET_KEY=your_secret_key_here_replace_me

# --- Metabase ---
METABASE_VERSION=latest
METABASE_PORT=3000
METABASE_DB_USER=metabase
METABASE_DB_PASSWORD=metabase_secret_2024

# --- Semantic Layer (PostgreSQL) ---
SEMANTIC_DB_NAME=universidad_analytics
SEMANTIC_DB_USER=analytics
SEMANTIC_DB_PASSWORD=analytics_secret_2024

# --- ETL Schedule ---
# Cron expression for data sync (default: every 12 hours at 00:00 and 12:00)
ETL_SCHEDULE_INTERVAL="0 0,12 * * *"
# Lookback window in hours for incremental extraction
ETL_LOOKBACK_HOURS=13
